.gitignore# 파이썬 가상환경 제외
backend/venv/
backend/.venv/
**/__pycache__/
*.pyc

# 미디어 임시 저장소 파일 제외 (폴더 구조는 유지하되 안의 파일은 제외)
backend/storage/inputs/*
backend/storage/outputs/*
!backend/storage/inputs/.gitkeep
!backend/storage/outputs/.gitkeep

# 노드 모듈 및 빌드 결과물 제외
frontend/node_modules/
frontend/dist/
frontend/.env*

# OS 및 에디터 설정 파일 제외
.DS_Store
.vscode/
.idea/

# 실행 파일 제외
ffmpeg.exe
ffprobe.exe
